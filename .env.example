# ================================================================
# ხელოსანი.ge Backend — Environment Variables
# ================================================================
# გადაარქვი: .env.example → .env
# .env არ ატვირთო Git-ში! (.gitignore-ში დაამატე)
# ================================================================

# ── Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
SITE_URL=http://localhost:3000

# ── JWT ─────────────────────────────────────────────────────────
# გენერაცია: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_very_long_random_string_at_least_64_chars

# ── CORS ─────────────────────────────────────────────────────────
# Production: CORS_ORIGIN=https://xelosani.ge
CORS_ORIGIN=*

# ── PostgreSQL ──────────────────────────────────────────────────
# Local: postgresql://postgres:password@localhost:5432/xelosani
# Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Railway: (auto-provided)
DATABASE_URL="postgresql://postgres:password@localhost:5432/xelosani"

# ── SendGrid ────────────────────────────────────────────────────
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@xelosani.ge

# ── Cloudinary ──────────────────────────────────────────────────
# https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret_here
CLOUDINARY_UPLOAD_PRESET=xelosani_uploads

# ── TBC Pay ─────────────────────────────────────────────────────
# https://developer.tbcbank.ge/ → Business → Sandbox credentials first
TBC_PAY_CLIENT_ID=your_tbc_client_id
TBC_PAY_CLIENT_SECRET=your_tbc_client_secret
# Sandbox: https://api.tbcpayments.ge (same URL, different credentials)
# Production: https://api.tbcpayments.ge
TBC_PAY_API_BASE=https://api.tbcpayments.ge

# ── Gemini AI ───────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
