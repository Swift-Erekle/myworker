# ================================================================
# ხელოსანი.ge Backend — Environment Variables
# ================================================================
# გადაარქვი: .env.example → .env
# .env არ ატვირთო Git-ში! (.gitignore-ში დაამატე)
# ================================================================

# ── Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
SITE_URL=http://localhost:3000

# ── JWT ─────────────────────────────────────────────────────────
