// prisma/schema.prisma
// ════════════════════════════════════════════════════════════════
// CHANGES v4:
// 1. Added PushSubscription model for Web Push Notifications
// ════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// მომხმარებლები
// ─────────────────────────────────────────────────────────────
model User {
  id             String    @id @default(cuid())
  name           String
  surname        String?
  email          String    @unique
  phone          String?
  password       String
  type           String    // user, handyman, company, staff, admin
  specialty      String?
  specialties    String[]  @default([])
  city           String?
  desc           String?
  services       Json      @default("[]")
  emoji          String    @default("🔧")
  color          String    @default("#22222f")
  avatar         String?
  verified       Boolean   @default(false)
  emailVerified  Boolean   @default(false)
  jobs           Int       @default(0)
  blocked        Boolean   @default(false)
  portfolio      Json      @default("[]")

  // ── VIP ────────────────────────────────────────────────────
  vipType        String    @default("none")  // none, vip, vipp
  vipExpiresAt   DateTime?
  vipActivatedAt DateTime?

  // ── Subscription plan ──────────────────────────────────────
  plan               String    @default("start")  // start, pro, top
  planExpiresAt      DateTime?
  trialExpiresAt     DateTime?
  usedFreeTrial      Boolean   @default(false)
  subscriptionStatus String    @default("active")  // active, expired, cancelled
  autoRenew          Boolean   @default(true)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  requests             Request[]
  offers               Offer[]
  reviewsReceived      Review[]             @relation("handyman")
  reviewsGiven         Review[]             @relation("reviewer")
  chatsAsUser          Chat[]               @relation("user")
  chatsAsHandyman      Chat[]               @relation("handyman")
  supportRequests      SupportRequest[]
  vipPayments          VipPayment[]
  subscriptionPayments SubscriptionPayment[]
  savedCards           SavedCard[]
  pushSubscriptions    PushSubscription[]   // ✅ Web push
  expoPushTokens       ExpoPushToken[]      // ✅ Mobile push
  favoriteRequests     FavoriteRequest[]    // ✅ Bookmarked requests
  notifications        Notification[]       // ✅ In-app bell notifications

  @@index([type])
  @@index([email])
  // ✅ DS#6: cron performance — plan/vip expiry checks
  @@index([plan, planExpiresAt])
  @@index([vipType, vipExpiresAt])
}

// ─────────────────────────────────────────────────────────────
// ✅ NEW: Web Push Subscriptions
// ─────────────────────────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique          // browser push endpoint URL
  p256dh    String                    // public key
  auth      String                    // auth secret
  createdAt DateTime @default(now())

  @@index([userId])
}


// ─────────────────────────────────────────────────────────────
// ✅ Expo Push Tokens (Mobile App — iOS & Android)
// ─────────────────────────────────────────────────────────────
model ExpoPushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique          // ExponentPushToken[xxxx]
  platform  String?                   // ios, android
  createdAt DateTime @default(now())

  @@index([userId])
}
// ─────────────────────────────────────────────────────────────
// მიბმული ბარათები (TBC Pay recurring tokens)
// ─────────────────────────────────────────────────────────────
model SavedCard {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  last4     String
  brand     String   @default("Card")
  expiry    String   @default("")
  token     String   @unique    // ✅ DS#9: unique to prevent race-duplicates
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// ვერიფიკაციის კოდები
// ─────────────────────────────────────────────────────────────
model VerifyCode {
  email     String   @id
  code      String
  type      String   // verify, reset
  expiresAt DateTime

  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────
// მოთხოვნები
// ─────────────────────────────────────────────────────────────
model Request {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  category  String
  desc      String?
  city      String   @default("თბილისი")
  budget    Int?
  urgency   String   @default("normal")
  status    String   @default("open")  // open, pending, in_progress, completed, closed, archived
  media     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offers    Offer[]
  chats     Chat[]
  favorites FavoriteRequest[]

  @@index([userId])
  @@index([status])
  @@index([category])
  // ✅ DS#6: cron — find stale open/pending requests by date
  @@index([status, createdAt])
}

// ─────────────────────────────────────────────────────────────
// შეთავაზებები
// ─────────────────────────────────────────────────────────────
model Offer {
  id         String   @id @default(cuid())
  requestId  String
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  handymanId String
  handyman   User     @relation(fields: [handymanId], references: [id], onDelete: Cascade)
  price      Int
  duration        String?       // human-readable e.g. "2 დღე"
  durationMinutes Int?          // precise minutes for server-side countdown
  comment    String?
  status     String   @default("pending")  // pending, accepted, agreed, completed, rejected, disagreed
  agreedAt   DateTime?                     // when user pressed "შევთანხმდით"
  completedAt DateTime?                    // deadline when work is due
  reviewReminderSent Boolean @default(false)
  createdAt  DateTime @default(now())

  chat Chat?

  @@unique([requestId, handymanId])
  @@index([handymanId])
  @@index([requestId])
  @@index([handymanId, status, createdAt])
  @@index([status, completedAt])
}

// ─────────────────────────────────────────────────────────────
// ჩათები
// ─────────────────────────────────────────────────────────────
model Chat {
  id         String   @id @default(cuid())
  offerId    String   @unique
  offer      Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  requestId  String
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("user",     fields: [userId],     references: [id])
  handymanId String
  handyman   User     @relation("handyman", fields: [handymanId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages Message[]

  @@index([userId])
  @@index([handymanId])
  @@index([requestId])
}

// ─────────────────────────────────────────────────────────────
// შეტყობინებები
// ─────────────────────────────────────────────────────────────
model Message {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  fromId    String?  // null = system message
  type      String   @default("text")  // text, image, video, voice, system
  content   String
  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([fromId])
  // ✅ DS#11: chat pagination — messages in chat by date
  @@index([chatId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// შეფასებები
// ─────────────────────────────────────────────────────────────
model Review {
  id         String   @id @default(cuid())
  reviewerId String
  reviewer   User     @relation("reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  handymanId String
  handyman   User     @relation("handyman", fields: [handymanId], references: [id], onDelete: Cascade)
  stars      Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([reviewerId, handymanId])
  @@index([handymanId])
}

// ─────────────────────────────────────────────────────────────
// Notification — in-app bell notifications (separate from push)
// ─────────────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String                          // who receives it
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String                          // 'new_offer', 'offer_accepted', 'offer_rejected', 'new_message', 'request_update', etc.
  title     String
  body      String?
  // Optional link target — e.g. chatId or requestId
  link      String?                         // e.g. '?chat=xxx' or '?req=yyy'
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// FavoriteRequest — handyman bookmarks a request for later
// ─────────────────────────────────────────────────────────────
model FavoriteRequest {
  id         String   @id @default(cuid())
  userId     String                          // the one who favorited (handyman or company)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestId  String
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, requestId])
  @@index([userId])
  @@index([requestId])
}

// ─────────────────────────────────────────────────────────────
// სუპორტი
// ─────────────────────────────────────────────────────────────
model SupportRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("pending")  // pending, active, closed
  lastMsg   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages SupportMessage[]

  @@index([status])
}

model SupportMessage {
  id               String         @id @default(cuid())
  supportRequestId String
  supportRequest   SupportRequest @relation(fields: [supportRequestId], references: [id], onDelete: Cascade)
  fromRole         String         // user, operator
  content          String
  createdAt        DateTime       @default(now())
}

// ─────────────────────────────────────────────────────────────
// VIP გადახდები
// ─────────────────────────────────────────────────────────────
model VipPayment {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vipType    String    // vip, vipp, bind
  days       Int
  amount     Int
  status     String    @default("pending")  // pending, paid, failed
  tbcOrderId String?   @unique
  tbcPayId   String?
  paidAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([status])
  // ✅ DS#11: payment history by user + status
  @@index([userId, status])
}

// ─────────────────────────────────────────────────────────────
// სუბსქრიფციის გადახდები (Pro / Top)
// ─────────────────────────────────────────────────────────────
model SubscriptionPayment {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          String    // pro, top
  amount        Int
  status        String    @default("pending")  // pending, paid, failed
  tbcOrderId    String?   @unique
  tbcPayId      String?
  periodStart   DateTime?
  periodEnd     DateTime?
  paidAt        DateTime?
  isAutoRenewal Boolean   @default(false)
  cardId        String?
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([status])
  // ✅ DS#11: payment history by user + status
  @@index([userId, status])
}