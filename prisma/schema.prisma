// prisma/schema.prisma
// ════════════════════════════════════════════════════════════════
// FIXES vs previous version:
// 1. Message.fromId → String? (nullable) — fixes FK violation
//    when system messages use fromId: 'system' (no real user)
// 2. Message.from removed FK relation — system msg safe
// 3. Added subscriptionStatus field to User
// ════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// მომხმარებლები
// ─────────────────────────────────────────────────────────────
model User {
  id             String    @id @default(cuid())
  name           String
  surname        String?
  email          String    @unique
  phone          String?
  password       String
  type           String    // user, handyman, company, staff, admin
  specialty      String?
  specialties    String[]  @default([])
  city           String?
  desc           String?
  services       Json      @default("[]")
  emoji          String    @default("🔧")
  color          String    @default("#22222f")
  avatar         String?
  verified       Boolean   @default(false)
  emailVerified  Boolean   @default(false)
  jobs           Int       @default(0)
  blocked        Boolean   @default(false)
  portfolio      Json      @default("[]")

  // ── VIP ────────────────────────────────────────────────────
  vipType        String    @default("none")  // none, vip, vipp
  vipExpiresAt   DateTime?
  vipActivatedAt DateTime?

  // ── Subscription plan ──────────────────────────────────────
  plan               String    @default("start")  // start, pro, top
  planExpiresAt      DateTime?                     // null = no paid plan active
  trialExpiresAt     DateTime?                     // null = trial not started
  usedFreeTrial      Boolean   @default(false)
  subscriptionStatus String    @default("active")  // active, expired, cancelled

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  requests             Request[]
  offers               Offer[]
  reviewsReceived      Review[]             @relation("handyman")
  reviewsGiven         Review[]             @relation("reviewer")
  chatsAsUser          Chat[]               @relation("user")
  chatsAsHandyman      Chat[]               @relation("handyman")
  supportRequests      SupportRequest[]
  vipPayments          VipPayment[]
  subscriptionPayments SubscriptionPayment[]

  @@index([type])
  @@index([email])
}

// ─────────────────────────────────────────────────────────────
// ვერიფიკაციის კოდები
// ─────────────────────────────────────────────────────────────
model VerifyCode {
  email     String   @id
  code      String
  type      String   // verify, reset
  expiresAt DateTime

  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────
// მოთხოვნები
// ─────────────────────────────────────────────────────────────
model Request {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  category  String
  desc      String?
  city      String   @default("თბილისი")
  budget    Int?
  urgency   String   @default("normal")
  status    String   @default("open")  // open, in_progress, completed
  media     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offers Offer[]

  @@index([userId])
  @@index([status])
  @@index([category])
}

// ─────────────────────────────────────────────────────────────
// შეთავაზებები
// ─────────────────────────────────────────────────────────────
model Offer {
  id         String   @id @default(cuid())
  requestId  String
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  handymanId String
  handyman   User     @relation(fields: [handymanId], references: [id], onDelete: Cascade)
  price      Int
  duration   String?
  comment    String?
  status     String   @default("pending")  // pending, accepted, rejected
  createdAt  DateTime @default(now())

  chat Chat?

  @@unique([requestId, handymanId])
  @@index([handymanId])
  @@index([requestId])
}

// ─────────────────────────────────────────────────────────────
// ჩათები
// ─────────────────────────────────────────────────────────────
model Chat {
  id         String   @id @default(cuid())
  offerId    String   @unique
  offer      Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  requestId  String
  userId     String
  user       User     @relation("user",     fields: [userId],     references: [id])
  handymanId String
  handyman   User     @relation("handyman", fields: [handymanId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages Message[]

  @@index([userId])
  @@index([handymanId])
}

// ─────────────────────────────────────────────────────────────
// შეტყობინებები
// ════════════════════════════════════════════════════════════════
// BUG FIX: fromId is now String? (nullable) so system messages
// (fromId: null, type: 'system') don't violate FK constraints.
// Previous: fromId String + User? relation → PostgreSQL FK error
// ════════════════════════════════════════════════════════════════
model Message {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  fromId    String?  // null = system message; userId otherwise
  type      String   @default("text")  // text, image, video, voice, system
  content   String
  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([fromId])
}

// ─────────────────────────────────────────────────────────────
// შეფასებები
// ─────────────────────────────────────────────────────────────
model Review {
  id         String   @id @default(cuid())
  reviewerId String
  reviewer   User     @relation("reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  handymanId String
  handyman   User     @relation("handyman", fields: [handymanId], references: [id], onDelete: Cascade)
  stars      Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([reviewerId, handymanId])
  @@index([handymanId])
}

// ─────────────────────────────────────────────────────────────
// სუპორტი
// ─────────────────────────────────────────────────────────────
model SupportRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("pending")  // pending, active, closed
  lastMsg   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages SupportMessage[]

  @@index([status])
}

model SupportMessage {
  id               String         @id @default(cuid())
  supportRequestId String
  supportRequest   SupportRequest @relation(fields: [supportRequestId], references: [id], onDelete: Cascade)
  fromRole         String         // user, operator
  content          String
  createdAt        DateTime       @default(now())
}

// ─────────────────────────────────────────────────────────────
// VIP გადახდები
// ─────────────────────────────────────────────────────────────
model VipPayment {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vipType    String    // vip, vipp
  days       Int
  amount     Int       // tetri (200 = 2₾)
  status     String    @default("pending")  // pending, paid, failed
  tbcOrderId String?   @unique
  tbcPayId   String?
  paidAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// სუბსქრიფციის გადახდები (Pro / Top)
// ─────────────────────────────────────────────────────────────
model SubscriptionPayment {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        String    // pro, top
  amount      Int       // tetri (2900 = 29₾)
  status      String    @default("pending")  // pending, paid, failed
  tbcOrderId  String?   @unique
  tbcPayId    String?
  periodStart DateTime?
  periodEnd   DateTime?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([status])
}
